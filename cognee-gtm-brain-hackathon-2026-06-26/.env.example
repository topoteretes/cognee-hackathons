# ---------------------------------------------------------------------------
# gtm-brain configuration. Copy to .env and fill in. The .env is gitignored.
# ---------------------------------------------------------------------------

# REQUIRED — cognify and recall use an LLM. An OpenAI key works.
LLM_API_KEY=sk-...

# Which Cognee dataset everything lands in (one unified graph).
COGNEE_DATASET=gtm_brain

# --- Offline GTM-brain ingest (the hackathon default) ----------------------
# `python scripts/run_gtm_ingest.py` reads this folder. Defaults to the
# vendored sample_data/gtm_brain when unset.
# GTM_BRAIN_DIR=sample_data/gtm_brain
# GTM_BRAIN_DISABLED=0

# When running the FULL `gtm-brain-ingest`, disable the live sources unless
# you have tokens (the GTM brain folder still ingests):
SLACK_DISABLED=1
GRANOLA_DISABLED=1

# --- Live Slack source (optional) ------------------------------------------
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNELS=C01234567,C07654321
# SLACK_PROJECT_MAP=C01234567:london-2027
# SLACK_DISABLED=0

# --- Live Granola source (optional) ----------------------------------------
# Reads the desktop app session automatically; usually nothing to set here.
# GRANOLA_DOC_IDS=https://notes.granola.ai/d/<uuid>
# GRANOLA_DISABLED=0

# --- Ingest tuning ---------------------------------------------------------
INGEST_SINCE_DAYS=30
INGEST_CONCURRENCY=1
# INGEST_LEGACY=1   # fall back to free-form remember() (no typed schema)

# --- Remote Cognee server (optional; in-process if unset) ------------------
# COGNEE_SERVICE_URL=https://your-cognee-server
# COGNEE_API_KEY=...

# --- Classifier ------------------------------------------------------------
CLASSIFIER_MODEL=gpt-4o-mini

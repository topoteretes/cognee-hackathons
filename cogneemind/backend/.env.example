# Copy this file to backend/.env and fill in real values. The .env file is
# gitignored and must NEVER be committed.

# ── LLM / Cognee brain (optional but recommended) ─────────────────────
# Without a key the brain runs in local-only mode (LocalWiki).
# With a key, brain.py wires up cognee 1.2.0.dev1 + the chat intent parser
# uses the same key for typo-tolerant LLM-first parsing.
LLM_API_KEY=sk-...

# ── Optional overrides ────────────────────────────────────────────────
# Pick which OpenAI-compatible model the chat intent parser uses.
# Defaults to gpt-4o-mini (fast, cheap, JSON-mode capable).
# LLM_MODEL=gpt-4o-mini

# Push the Cognee graph to Cognee Cloud instead of staying local.
# COGNEE_CLOUD_URL=https://cloud.cognee.ai
# COGNEE_API_KEY=...

# Copy to .env and fill in your key. .env is gitignored — never commit real keys.
# This brain was built against Scaleway Generative APIs (OpenAI-compatible).

# --- Chat / agent LLM ---
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-oss-120b                     # a strong tool/JSON-capable model
LLM_ENDPOINT=https://api.scaleway.ai/v1
LLM_API_KEY=your-key-here
COGNEE_SKIP_CONNECTION_TEST=true                  # cognee's 30s self-test is over-strict here
LLM_INSTRUCTOR_MODE=json_mode                     # gpt-oss tool-calling is unreliable; use JSON mode

# --- Embeddings ---
EMBEDDING_PROVIDER=openai_compatible              # engine for 3rd-party OpenAI-compatible endpoints
EMBEDDING_MODEL=bge-multilingual-gemma2
EMBEDDING_ENDPOINT=https://api.scaleway.ai/v1
EMBEDDING_API_KEY=your-key-here
EMBEDDING_DIMENSIONS=3584                          # must match the embedding model's real output dims

# --- Cognee Cloud (optional — "Best use of Cognee Cloud" bonus) ---
# COGNEE_CLOUD_URL=https://your-instance.cognee.ai
# COGNEE_API_KEY=ck_...

# --- LLM (provided at kickoff, or bring your own) ---
LLM_API_KEY=

# Skip cognee's flaky 30s LLM preflight check (real calls work fine).
COGNEE_SKIP_CONNECTION_TEST=true

# Optional: override provider/model
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# --- Cognee Cloud (optional, rewarded). Leave blank to run fully local. ---
COGNEE_CLOUD_URL=
COGNEE_API_KEY=

# --- Slack (Socket Mode) ---
# Bot token: starts with xoxb-  (OAuth & Permissions page)
SLACK_BOT_TOKEN=
# App-level token: starts with xapp-  (Basic Information -> App-Level Tokens, scope connections:write)
SLACK_APP_TOKEN=

# Slack user id of the human expert to tag when the brain can't answer (e.g. U0123ABCD)
RESPONSIBLE_PERSON=
